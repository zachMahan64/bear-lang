// tests/hir/54.br

deftype Int = i32;

compt [2]Int ints = [1, 2];

var _0 = @static_assert(ints[0] == 1); // fine

var _1 = @static_assert(ints[1] == 2); // fine

var _2 = @static_assert(ints[1] == 3); // oops

var _3 = @static_assert(ints[2] == 00); // oops, out of bounds

var _4 = @static_assert(ints[2 + 10 + 11 * 499] == 00); // oops, out of bounds

var _5 = @static_assert(ints["2"] == 00); // oops, not convertible

var _6 = @static_assert(ints[2.0] == 00); // oops, not convertible

compt &[2]Int ints1 = ints;

var _7 = @static_assert ints1[0] == ints[0]; // fine

var _8 = @static_assert ints1[0] == ints[-4]; // oops

compt str my_str = "abc";

var _9 = @static_assert(my_str[1] == 'b'); // oops

var _10 = @static_assert(my_str[1] == 'c'); // oops

var _11 = @static_assert(my_str[3] == 'c'); // oops
