// tests/hir/72.br

mod demo;

contract ToComptStr {
    compt mt to_compt_str() -> str;
}

compt fn to_compt_str(var item) -> str => {
    item.to_compt_str() if @has_contract(typeof item, ToComptStr)
        else item if @same_type(decay typeof item, str)
        else list_to_str(item) if @defined(item.len)
        else item as str
}

compt fn list_to_str(var list) -> str => ("[" + list_helper(list, 0) + "]")

compt fn list_helper(var list, var i) -> str => {
    "" if i == list.len 
        else to_compt_str(list[i]) + maybe_comma(list.len, i) + list_helper(list, i + 1) 
}

compt fn maybe_comma(var len, var i) => "" if (i >= len - 1) else ", "

compt [2]i32 a = [1, 2];

var _0 = @static_assert @defined(a.len);

var _1 = @static_assert to_compt_str(a) == "[1, 2]";

var _2 = @static_assert !@has_contract(typeof a, ToComptStr);
