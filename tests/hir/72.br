// tests/hir/72.br

mod demo;

mod util {

contract ToComptStr {
    compt mt to_compt_str() -> str;
}

compt fn to_compt_str(var item) -> str => {
    item.to_compt_str() if @has_contract(typeof item, ToComptStr)
        else item if @same_type(decay typeof item, str)
        else list_to_str(item) if @defined(item.len)
        else item as str
}

compt fn list_to_str(var list) -> str => ("[" + list_helper(list, 0) + "]")

compt fn list_helper(var list, var i) -> str => {
    "" if i == list.len 
        else to_compt_str(list[i]) + maybe_comma(list.len, i) + list_helper(list, i + 1) 
}

compt fn maybe_comma(var len, var i) => "" if (i >= len - 1) else ", "
}

compt [2]i32 a = [1, 2];

var _0 = @static_assert @defined(a.len);

var _1 = @static_assert util..to_compt_str(a) == "[1, 2]";

var _2 = @static_assert !@has_contract(typeof a, util..ToComptStr);

struct IntVec2 has util..ToComptStr {
    [2]i32 vals = [4, 2];
    fn new(i32 a, i32 b) -> Self => Self{.vals = [a, b]}
    compt mt to_compt_str() -> str => util..to_compt_str(self.vals)
}

var _3 = @static_assert IntVec2..new(1, 2).to_compt_str() == "[1, 2]";

deftype Vec2 = IntVec2;

compt Vec2 my_vec2 = Vec2..new(3, 3);

var _4 = @static_assert my_vec2.to_compt_str() == "[3, 3]";

var _5 = @static_assert my_vec2.to_compt_str() == "[3, 4]"; // oops

