// hir/tests/20.br 

mod ben {
    struct Ben {
        hid compt i32 ben; // oops
    }
    compt i32 benny = Ben..ben; // oops 
    hid compt i32 bar = 42; // fine
    
    hid mod foo {
        compt i32 thingy = 3;
    }

    pub mod ny {
        hid compt i32 boy = 12;
        hid struct Thingy {

        }
        struct Fooey {
            hid struct Gooey {

            }
        }
    }

}

compt i32 foo = ben..bar; // oops, hid

compt u64 fooey = 45; // fine

compt var fooey_dooey = fooey; // oops, hid

compt i32 thingy = ben..foo..thingy; // oops, hid

compt i32 benny = ben..ny..boy; // oops, hid

i32 A;

i32 B = A; // oops, should be compt-init

compt ben..ny..Thingy t = ben..ny..Thingy{}; // oops, hid

compt ben..ny..Fooey..Gooey fooey_gooey = ben..ny..Fooey..Gooey{}; //oops, hid
