// 00.br

fn main() {
    Foo foo = Foo{.data = 42};
    return foo.get_data();

}

struct Foo {
    i32 data;
}

mt Foo..get_data() {
    return self.data;
}

mt Foo..data() { // error, redefined
    return self.data;
}

mt Foo..set_data(i32 data) {
    self.data = data;
}

mod Boo { // warning, capital module

}

struct boo { // warning, lowercase struct, error empty

}
