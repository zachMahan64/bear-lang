// tests/parser/57.br

fn main() {
    
    // testing explicit vs implicit return types and plain expr vs block expr bodies

    i32 a = 12;
    
    var cl = || -> i32 => a;
    
    var cl1 = |i32 val| -> i32 => {return val *2;};
    
    *fn(i32,i32)->i32 cl2 = |i32 a, i32 b| -> i32 => a + b;

    *fn(i32,i32)->i32 cl3 = |i32 a, i32 b| => a + b;

    // getting arrows mixed up

    var cl4 = || -> {"oops"};  // oops

    var cl5 = || => str -> {"oops"}; // oops  

}
